---
interface Badge {
  icon: string;
  text: string;
}

interface CtaButton {
  label: string;
  href: string;
}

interface Props {
  headingLine1: string;
  headingHighlight: string;
  headingLine3: string;
  subtext: string;
  primaryCta: CtaButton;
  secondaryCta: CtaButton;
  badges: Badge[];
}

const {
  headingLine1,
  headingHighlight,
  headingLine3,
  subtext,
  primaryCta,
  secondaryCta,
  badges,
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__heading">
        <span class="hero__heading-line">{headingLine1}</span>
        <span class="hero__heading-highlight">{headingHighlight}</span>
        <span class="hero__heading-line">{headingLine3}</span>
      </h1>
      <p class="hero__subtext">{subtext}</p>
      <div class="hero__ctas">
        <a href={primaryCta.href} class="btn btn--primary">{primaryCta.label}</a>
        <a href={secondaryCta.href} class="btn btn--ghost">{secondaryCta.label} →</a>
      </div>
      <div class="hero__badges">
        {badges.map((badge) => (
          <span class="badge">
            <span class="badge__icon">{badge.icon}</span>
            <span class="badge__text">{badge.text}</span>
          </span>
        ))}
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__image-wrap">
        <img
          src="/images/hero-student.png"
          alt="HND Level 5 student at a UK college"
          class="hero__image"
          width="469"
          height="254"
          loading="eager"
        />
        <div class="hero__uk-badge">
          <svg class="hero__uk-flag" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" aria-label="UK flag">
            <clipPath id="t"><rect width="60" height="30"/></clipPath>
            <rect width="60" height="30" fill="#012169"/>
            <path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6" clip-path="url(#t)"/>
            <path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/>
            <path stroke="#C8102E" stroke-width="4" d="M0,0 L26,13 M34,17 L60,30 M60,0 L34,13 M26,17 L0,30" clip-path="url(#t)"/>
            <path d="M30,0 V30 M0,15 H60" stroke="#C8102E" stroke-width="6"/>
          </svg>
          <span>UK Specialists</span>
        </div>
        <div class="hero__card hero__card--1">
          <span class="hero__card-icon">🎓</span>
          <strong>Distinction Grade</strong>
          <span>HND Level 5 Specialist</span>
        </div>
        <div class="hero__card hero__card--2">
          <span class="hero__card-icon">⭐</span>
          <strong>4.9/5 Rating</strong>
          <span>7,500+ students</span>
        </div>
        <div class="hero__card hero__card--3">
          <span class="hero__card-icon">✓</span>
          <strong>Pearson BTEC & SQA</strong>
          <span>All subjects covered</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero__heading {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.12;
    color: var(--color-primary);
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-highlight {
    display: block;
    color: var(--color-accent);
  }

  .hero__subtext {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
    border: 2px solid transparent;
    white-space: nowrap;
  }

  .btn--primary {
    background-color: var(--color-accent);
    color: var(--color-white);
    border-color: var(--color-accent);
  }

  .btn--primary:hover {
    background-color: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--color-primary);
    border-color: var(--color-border-light);
    font-weight: 500;
  }

  .btn--ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background-color: var(--color-accent-light);
    color: var(--color-primary);
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .badge__icon {
    color: var(--color-accent-dark);
    font-weight: 800;
  }

  /* Visual / image right column */
  .hero__visual {
    position: relative;
  }

  .hero__image-wrap {
    position: relative;
    border-radius: 1.25rem;
    overflow: visible;
    box-shadow: 0 24px 64px rgba(27, 43, 75, 0.18);
  }

  .hero__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1.25rem;
    object-fit: cover;
    border: 4px solid var(--color-border-light);
  }

  /* UK flag badge — bottom-left corner of image */
  .hero__uk-badge {
    position: absolute;
    bottom: -1rem;
    left: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    border: 2px solid var(--color-border-light);
    border-radius: 2rem;
    padding: 0.35rem 0.9rem 0.35rem 0.45rem;
    box-shadow: 0 4px 16px rgba(27, 43, 75, 0.12);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.01em;
    z-index: 4;
  }

  .hero__uk-flag {
    width: 2rem;
    height: 1rem;
    border-radius: 0.2rem;
    flex-shrink: 0;
    display: block;
  }

  /* Floating stat cards */
  .hero__card {
    position: absolute;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: 1rem;
    padding: 0.875rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    box-shadow: 0 8px 32px rgba(27, 43, 75, 0.13);
    min-width: 160px;
    z-index: 3;
  }

  .hero__card strong {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .hero__card span:last-child {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .hero__card-icon {
    font-size: 1.375rem;
    margin-bottom: 0.15rem;
  }

  /* Card positions: floating over the image */
  .hero__card--1 {
    top: -1.25rem;
    right: -1.25rem;
  }

  .hero__card--2 {
    top: 50%;
    right: -1.5rem;
    transform: translateY(-50%);
  }

  .hero__card--3 {
    bottom: 2.5rem;
    right: -1.25rem;
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero__visual {
      display: block;
      padding: 0 1rem 1.5rem;
    }

    .hero__card--1,
    .hero__card--2,
    .hero__card--3 {
      display: none;
    }

    .hero__uk-badge {
      bottom: -0.75rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 3rem 0 2.5rem;
    }

    .hero__ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
